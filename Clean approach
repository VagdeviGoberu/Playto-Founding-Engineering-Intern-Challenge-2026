class KYCStateMachine:
    TRANSITIONS = {
        "draft": ["submitted"],
        "submitted": ["under_review"],
        "under_review": ["approved", "rejected", "more_info_requested"],
        "more_info_requested": ["submitted"],
        "approved": [],
        "rejected": [],
    }

    @classmethod
    def can_transition(cls, from_state, to_state):
        return to_state in cls.TRANSITIONS.get(from_state, [])

    @classmethod
    def transition(cls, instance, to_state):
        if not cls.can_transition(instance.status, to_state):
            raise ValidationError(
                f"Illegal transition from {instance.status} to {to_state}"
            )
        instance.status = to_state
        instance.save()
